APP_NAME="AutoScout24 SafeTrade"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=autoscout24
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3004,127.0.0.1,127.0.0.1:8000,::1

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004

# ──────────────────────────────────────────────────
# PRODUCTION VALUES (set these on Laravel Forge)
# ──────────────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://adminautoscout.dev
# FRONTEND_URL=https://www.autoscout24safetrade.com
# SESSION_DRIVER=database
# SESSION_DOMAIN=.adminautoscout.dev
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
# SANCTUM_STATEFUL_DOMAINS=www.autoscout24safetrade.com,autoscout24safetrade.com,adminautoscout.dev
# CORS_ALLOWED_ORIGINS=https://www.autoscout24safetrade.com,https://autoscout24safetrade.com
# TRUSTED_PROXIES=*
# ──────────────────────────────────────────────────

# Mail Configuration
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# MailerSend (set MAIL_MAILER=mailersend to use)
MAILERSEND_API_KEY=

# AWS (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe (optional)
STRIPE_KEY=
STRIPE_SECRET=

# Bulk Import
BULK_IMPORT_KEY=

# Image Import (timing-safe key for image import endpoint)
IMAGE_IMPORT_KEY=

TRUSTED_PROXIES=

# AutoScout24 API (optional)
AUTOSCOUT24_API_URL=
AUTOSCOUT24_API_KEY=
AUTOSCOUT24_API_SECRET=
AUTOSCOUT24_WEBHOOK_SECRET=

# Internal Management
BANK_API_PROVIDER=internal
COMPLIANCE_KYC_PROVIDER=internal
OCR_PROVIDER=manual

# Sanctum Token Expiration (days, max 30)
SANCTUM_TOKEN_EXPIRATION_DAYS=7

# Database Seeder Passwords (auto-generated if not set)
SEED_USER_PASSWORD=
SEED_ADMIN_PASSWORD=
